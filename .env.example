# Backblaze B2 (required)
B2_ENDPOINT=your_b2_endpoint
B2_REGION=your_b2_region
B2_APPLICATION_KEY_ID=your_application_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_APPLICATION_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=K001AbCdEfGhIjKlMnOpQrStUvWxYz0=
# B2_BUCKET_NAME=my-research-cache

# Optional — public base URL for objects in a public bucket. When set, the API
# builds direct links instead of presigned URLs. Leave unset for private buckets.
# B2_PUBLIC_URL=https://your-bucket.s3.us-west-004.backblazeb2.com

# Anthropic (required) — powers the research agent (Claude Sonnet 4.6 tool-use loop).
# Get a key at https://console.anthropic.com/. Never commit a real key.
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional overrides (defaults shown):
# ANTHROPIC_MODEL=claude-sonnet-4-6
# RESEARCH_MAX_SEARCHES=8
# RESEARCH_MAX_SOURCES=8
# RESEARCH_EFFORT=medium
